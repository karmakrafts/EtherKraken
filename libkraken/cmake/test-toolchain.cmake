set(CMAKE_C_COMPILER clang-20)
set(CMAKE_CXX_COMPILER clang++-20)

set(CMAKE_C_FLAGS "-march=x86-64-v2")
set(CMAKE_CXX_FLAGS "-march=x86-64-v2")
set(CMAKE_C_COMPILER_TARGET "x86_64-linux-gnu")
set(CMAKE_CXX_COMPILER_TARGET "x86_64-linux-gnu")
set(CMAKE_EXE_LINKER_FLAGS "-fuse-ld=lld-20 --rtlib=compiler-rt --target=x86_64-linux-gnu")
set(CMAKE_SHARED_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS}")
set(CMAKE_MODULE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS}")
set(CMAKE_POSITION_INDEPENDENT_CODE ON)